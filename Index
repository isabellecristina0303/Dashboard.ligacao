<script>
// ── STORAGE ──────────────────────────────────────────────────
const SK = 'igreen_edits_v3';
const CK = 'igreen_custom_objs_v3';
const BK = 'igreen_blocks_v3';

function load(key) { try { return JSON.parse(localStorage.getItem(key)||'{}'); } catch { return {}; } }
function loadArr(key) { try { return JSON.parse(localStorage.getItem(key)||'[]'); } catch { return []; } }
function save(key, data) { localStorage.setItem(key, JSON.stringify(data)); }

// ── NAVIGATION ────────────────────────────────────────────────
function showCard(id) {
  document.querySelectorAll('.objection-card').forEach(c => c.classList.remove('visible'));
  document.querySelectorAll('.nav-item, .custom-obj-item').forEach(n => n.classList.remove('active'));
  const card = document.getElementById('card-' + id);
  if (card) card.classList.add('visible');
  document.querySelectorAll('.nav-item').forEach(n => {
    if (n.getAttribute('onclick') && n.getAttribute('onclick').includes("'"+id+"'")) n.classList.add('active');
  });
  document.querySelectorAll('.custom-obj-item').forEach(n => {
    if (n.getAttribute('data-id') === id) n.classList.add('active');
  });
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function filterNav(query) {
  const q = query.toLowerCase();
  document.querySelectorAll('#navList .nav-item').forEach(item => {
    const label = (item.querySelector('.label')?.textContent || '').toLowerCase();
    const tags = (item.getAttribute('data-tags') || '').toLowerCase();
    item.style.display = (!q || label.includes(q) || tags.includes(q)) ? '' : 'none';
  });
}
function filterProfile(profile, el) {
  document.querySelectorAll('.ptag').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
}

// ── INLINE EDITING ────────────────────────────────────────────
function enableEdit(el) {
  if (el.contentEditable === 'true') return;
  el.contentEditable = 'true';
  el.classList.add('editing');
  el.focus();
  // move cursor to end
  const range = document.createRange();
  range.selectNodeContents(el);
  range.collapse(false);
  const sel = window.getSelection();
  sel.removeAllRanges();
  sel.addRange(range);
}

function disableEdit(el) {
  el.contentEditable = 'false';
  el.classList.remove('editing');
  const key = el.getAttribute('data-key');
  if (key) {
    const edits = load(SK);
    edits[key] = el.innerHTML;
    save(SK, edits);
  }
}

// Apply saved edits on load
function applyEdits() {
  const edits = load(SK);
  Object.entries(edits).forEach(([key, html]) => {
    const el = document.querySelector(`[data-key="${key}"]`);
    if (el) el.innerHTML = html;
  });
}

// Global blur listener for any contenteditable
document.addEventListener('focusout', e => {
  if (e.target && e.target.contentEditable === 'true') {
    disableEdit(e.target);
  }
});

// Prevent Enter from creating new lines in scripts (use Shift+Enter)
document.addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey && e.target.contentEditable === 'true') {
    e.preventDefault();
    e.target.blur();
  }
});

// ── ADD CUSTOM BLOCKS ─────────────────────────────────────────
function addBlock(cardId) {
  const blocks = load(BK);
  if (!blocks[cardId]) blocks[cardId] = [];
  const idx = blocks[cardId].length;
  blocks[cardId].push({ label: '', text: '', type: 'script' });
  save(BK, blocks);
  renderBlocks(cardId);
  // focus new textarea
  setTimeout(() => {
    const container = document.getElementById('blocks-' + cardId);
    if (container) {
      const areas = container.querySelectorAll('textarea');
      if (areas.length) areas[areas.length-1].focus();
    }
  }, 60);
}

function updateBlock(cardId, idx, field, value) {
  const blocks = load(BK);
  if (!blocks[cardId] || !blocks[cardId][idx]) return;
  blocks[cardId][idx][field] = value;
  save(BK, blocks);
}

function deleteBlock(cardId, idx) {
  const blocks = load(BK);
  if (!blocks[cardId]) return;
  blocks[cardId].splice(idx, 1);
  save(BK, blocks);
  renderBlocks(cardId);
}

function renderBlocks(cardId) {
  const container = document.getElementById('blocks-' + cardId);
  if (!container) return;
  const blocks = load(BK);
  const cardBlocks = blocks[cardId] || [];
  if (cardBlocks.length === 0) { container.innerHTML = ''; return; }
  container.innerHTML = cardBlocks.map((b, i) => `
    <div class="custom-block">
      <div class="cb-header">
        <select class="cb-type-sel" onchange="updateBlock('${cardId}',${i},'type',this.value)">
          <option value="script" ${b.type==='script'?'selected':''}>💬 Script</option>
          <option value="variant" ${b.type==='variant'?'selected':''}>🔀 Variante</option>
          <option value="tip" ${b.type==='tip'?'selected':''}>💡 Dica</option>
          <option value="alert" ${b.type==='alert'?'selected':''}>⚠️ Atenção</option>
        </select>
        <input class="cb-label-input" type="text" placeholder="Título (ex: Para cliente idoso)..."
          value="${escH(b.label||'')}" oninput="updateBlock('${cardId}',${i},'label',this.value)">
        <button class="cb-del" onclick="deleteBlock('${cardId}',${i})" title="Excluir">✕</button>
      </div>
      <textarea class="cb-textarea" placeholder="Escreva aqui o script ou argumentação..."
        oninput="updateBlock('${cardId}',${i},'text',this.value)">${escH(b.text||'')}</textarea>
    </div>
  `).join('');
}

function renderAllBlocks() {
  const blocks = load(BK);
  Object.keys(blocks).forEach(cardId => renderBlocks(cardId));
}

function escH(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ── CUSTOM OBJECTIONS (sidebar) ───────────────────────────────
function loadCustomObjs() { return loadArr(CK); }
function saveCustomObjs(d) { save(CK, d); }

function renderCustomObjList() {
  const objs = loadCustomObjs();
  const list = document.getElementById('customObjList');
  if (!list) return;
  list.innerHTML = objs.map((obj, i) => `
    <div class="custom-obj-item" data-id="custom-${i}" onclick="showCard('custom-${i}')">
      <span class="c-icon">${obj.emoji||'📌'}</span>
      <span class="c-label">${escH(obj.title)}</span>
      <button class="del-obj" onclick="event.stopPropagation();deleteCustomObj(${i})" title="Excluir">✕</button>
    </div>
  `).join('');
}

function renderCustomCards() {
  const objs = loadCustomObjs();
  document.querySelectorAll('.custom-obj-card').forEach(el => el.remove());
  const main = document.querySelector('main.content');
  objs.forEach((obj, i) => {
    const div = document.createElement('div');
    div.className = 'objection-card custom-obj-card';
    div.id = 'card-custom-' + i;
    div.innerHTML = `
      <div class="card-header">
        <div class="card-emoji">${obj.emoji||'📌'}</div>
        <div class="card-title">
          <h2>${escH(obj.title)}</h2>
          <p>${escH(obj.subtitle||'Objeção personalizada')}</p>
        </div>
      </div>
      <p class="edit-hint">✏️ Clique em qualquer texto para editar · Enter para salvar · Shift+Enter para nova linha</p>
      <div class="steps">
        <div class="step">
          <div class="step-header"><span class="step-icon">💬</span><span class="step-label">Argumentação principal</span></div>
          <div class="step-body">
            <div class="script" data-key="cobj_${i}_script" contenteditable="false" onclick="enableEdit(this)">${escH(obj.script||'Clique para editar...')}</div>
            ${obj.notes ? `<p data-key="cobj_${i}_notes" contenteditable="false" onclick="enableEdit(this)" style="margin-top:10px">${escH(obj.notes)}</p>` : ''}
          </div>
        </div>
      </div>
      <button class="add-block-btn" onclick="addBlock('custom-${i}')">＋ Adicionar argumentação</button>
      <div class="custom-blocks" id="blocks-custom-${i}"></div>
    `;
    main.appendChild(div);
  });
  renderAllBlocks();
}

function deleteCustomObj(index) {
  if (!confirm('Excluir esta objeção?')) return;
  const objs = loadCustomObjs();
  objs.splice(index, 1);
  saveCustomObjs(objs);
  renderCustomObjList();
  renderCustomCards();
  showCard('home');
}

function openNewObjForm() {
  showCard('new-obj-form');
}

function buildNewObjFormCard() {
  const main = document.querySelector('main.content');
  const existing = document.getElementById('card-new-obj-form');
  if (existing) return;
  const div = document.createElement('div');
  div.className = 'objection-card';
  div.id = 'card-new-obj-form';
  div.innerHTML = `
    <div class="card-header">
      <div class="card-emoji">➕</div>
      <div class="card-title"><h2>Nova Objeção</h2><p>Crie sua própria objeção com argumentação personalizada</p></div>
    </div>
    <div style="display:flex;flex-direction:column;gap:12px;max-width:600px;">
      <div style="display:flex;gap:10px;flex-wrap:wrap;">
        <input id="nof-emoji" class="form-inp" style="max-width:80px" type="text" placeholder="📌" maxlength="2">
        <input id="nof-title" class="form-inp" style="flex:1" type="text" placeholder="Título da objeção...">
      </div>
      <input id="nof-subtitle" class="form-inp" type="text" placeholder="Descrição curta (opcional)">
      <textarea id="nof-script" class="form-ta" placeholder="Script principal — o que dizer ao cliente..."></textarea>
      <textarea id="nof-notes" class="form-ta" placeholder="Observações internas (opcional)..."></textarea>
      <div style="display:flex;gap:8px;">
        <button class="btn-save-obj" onclick="saveNewObj()">Salvar objeção</button>
        <button class="btn-cancel-obj" onclick="showCard('home')">Cancelar</button>
      </div>
    </div>
  `;
  main.appendChild(div);
}

function saveNewObj() {
  const emoji = document.getElementById('nof-emoji').value.trim() || '📌';
  const title = document.getElementById('nof-title').value.trim();
  const subtitle = document.getElementById('nof-subtitle').value.trim();
  const script = document.getElementById('nof-script').value.trim();
  const notes = document.getElementById('nof-notes').value.trim();
  if (!title) { alert('Digite um título para a objeção.'); return; }
  const objs = loadCustomObjs();
  objs.push({ emoji, title, subtitle, script, notes });
  saveCustomObjs(objs);
  ['nof-emoji','nof-title','nof-subtitle','nof-script','nof-notes'].forEach(id => {
    const el = document.getElementById(id); if (el) el.value = '';
  });
  renderCustomObjList();
  renderCustomCards();
  showCard('custom-' + (objs.length - 1));
}

// ── INIT ──────────────────────────────────────────────────────
buildNewObjFormCard();
renderCustomObjList();
renderCustomCards();
applyEdits();
renderAllBlocks();
showCard('home');
</script>
</body>
</html>
