  {nome:"Thauane Borges",            id:"2038",total:467, tme_sec:175.1,tma_sec:715.0,tme:"02:55",tma:"11:55",taxa_avaliacao:35.1,csat:94.5},
  {nome:"Rafaela Wayne",             id:"2086",total:536, tme_sec:236.5,tma_sec:503.5,tme:"03:56",tma:"08:23",taxa_avaliacao:37.3,csat:87.5},
