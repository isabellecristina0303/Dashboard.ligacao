<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Consultor de Retenção — iGreen</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap');

  :root {
    --bg:      #000000;
    --surface: #050f08;
    --surface2:#0a0a0a;
    --border:  #1a3322;
    --accent:  #22c55e;
    --text:    #ffffff;
    --muted:   #4ade80;
    --good:    #22c55e;
    --mid:     #a3e635;
    --bad:     #f87171;
    --tag-bg:  #052e16;
    --tag-border: #14532d;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ── HEADER ── */
  header {
    background: #000;
    border-bottom: 1px solid #1a3322;
    padding: 14px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .logo { display: flex; align-items: center; gap: 10px; }
  .logo-dot { width: 9px; height: 9px; background: var(--accent); border-radius: 50%; box-shadow: 0 0 8px #22c55e88; flex-shrink: 0; }
  .logo h1 { font-size: 1rem; font-weight: 700; color: #fff; }
  .logo h1 span { color: var(--accent); }
  .logo p { font-size: 0.65rem; color: var(--muted); font-family: 'JetBrains Mono', monospace; opacity: 0.6; margin-top: 1px; }

  /* ── LAYOUT ── */
  .layout { display: grid; grid-template-columns: 280px 1fr; min-height: calc(100vh - 57px); }

  /* ── SIDEBAR ── */
  .sidebar {
    background: #050f08;
    border-right: 1px solid #1a3322;
    padding: 20px 0;
    overflow-y: auto;
    position: sticky;
    top: 57px;
    height: calc(100vh - 57px);
  }

  .sidebar-section { margin-bottom: 6px; }
  .sidebar-label {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    opacity: 0.5;
    padding: 10px 20px 6px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 20px;
    cursor: pointer;
    transition: background 0.1s;
    border-left: 2px solid transparent;
  }
  .nav-item:hover { background: #0a1a0f; }
  .nav-item.active { background: #0a1a0f; border-left-color: var(--accent); }
  .nav-item .icon { font-size: 1rem; flex-shrink: 0; width: 22px; text-align: center; }
  .nav-item .label { font-size: 0.8rem; font-weight: 500; color: #d1fae5; line-height: 1.3; }
  .nav-item.active .label { color: var(--accent); font-weight: 600; }

  /* profile filter */
  .profile-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 6px 20px 10px;
  }
  .ptag {
    background: #0a1a0f;
    border: 1px solid #1a3322;
    color: #86efac;
    padding: 4px 10px;
    border-radius: 5px;
    font-size: 0.7rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.1s;
  }
  .ptag:hover, .ptag.active { background: var(--accent); border-color: var(--accent); color: #000; font-weight: 700; }

  /* search */
  .search-wrap { padding: 0 16px 14px; }
  .search-wrap input {
    width: 100%;
    background: #000;
    border: 1px solid #1a3322;
    color: #fff;
    padding: 7px 12px;
    border-radius: 6px;
    font-size: 0.78rem;
    font-family: 'Inter', sans-serif;
    outline: none;
    transition: border-color 0.12s;
  }
  .search-wrap input:focus { border-color: var(--accent); }
  .search-wrap input::placeholder { color: #4ade80; opacity: 0.4; }

  /* ── CONTENT ── */
  .content { padding: 28px 36px; overflow-y: auto; }

  /* ── CARD ── */
  .objection-card { display: none; }
  .objection-card.visible { display: block; }

  .card-header {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    margin-bottom: 24px;
  }
  .card-emoji { font-size: 2rem; line-height: 1; flex-shrink: 0; }
  .card-title h2 { font-size: 1.3rem; font-weight: 700; color: #fff; letter-spacing: -0.3px; }
  .card-title p { font-size: 0.8rem; color: var(--muted); margin-top: 4px; opacity: 0.8; }

  /* tags row */
  .tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 22px; }
  .tag {
    background: var(--tag-bg);
    border: 1px solid var(--tag-border);
    color: #4ade80;
    padding: 3px 10px;
    border-radius: 5px;
    font-size: 0.7rem;
    font-weight: 600;
  }
  .tag.yellow { background: #1a2e10; border-color: #365314; color: #bef264; }
  .tag.red    { background: #2d0a0a; border-color: #7f1d1d; color: #fca5a5; }

  /* step blocks */
  .steps { display: flex; flex-direction: column; gap: 14px; margin-bottom: 28px; }
  .step {
    background: var(--surface);
    border: 1px solid #1a3322;
    border-radius: 10px;
    overflow: hidden;
  }
  .step-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    background: #000;
    border-bottom: 1px solid #1a3322;
  }
  .step-icon { font-size: 1rem; }
  .step-label {
    font-size: 0.67rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    opacity: 0.7;
  }
  .step-body { padding: 16px; }
  .step-body p { font-size: 0.875rem; color: #e2fce6; line-height: 1.65; margin-bottom: 10px; }
  .step-body p:last-child { margin-bottom: 0; }

  /* script quote */
  .script {
    background: #000;
    border-left: 3px solid var(--accent);
    border-radius: 0 8px 8px 0;
    padding: 12px 16px;
    margin: 10px 0;
    font-size: 0.875rem;
    color: #d1fae5;
    line-height: 1.6;
    font-style: italic;
  }
  .script strong { font-style: normal; color: var(--accent); font-weight: 600; }

  /* variants */
  .variants { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 12px; }
  .variant {
    background: #000;
    border: 1px solid #1a3322;
    border-radius: 8px;
    padding: 12px 14px;
  }
  .variant-label { font-size: 0.63rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); opacity: 0.65; margin-bottom: 6px; }
  .variant p { font-size: 0.82rem; color: #d1fae5; line-height: 1.55; font-style: italic; }

  /* impact phrases */
  .impact-box {
    background: var(--surface);
    border: 1px solid #1a3322;
    border-radius: 10px;
    padding: 16px 18px;
    margin-bottom: 14px;
  }
  .impact-box h4 { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); opacity: 0.65; margin-bottom: 12px; }
  .impact-list { display: flex; flex-direction: column; gap: 8px; }
  .impact-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    background: #000;
    border-left: 2px solid var(--accent);
    border-radius: 0 6px 6px 0;
    padding: 9px 12px;
    font-size: 0.82rem;
    color: #d1fae5;
    line-height: 1.5;
    font-style: italic;
  }

  /* alert box */
  .alert {
    background: #1a2e10;
    border: 1px solid #365314;
    border-radius: 8px;
    padding: 12px 16px;
    font-size: 0.82rem;
    color: #bef264;
    line-height: 1.55;
    margin: 10px 0;
    display: flex;
    gap: 8px;
  }
  .alert-icon { flex-shrink: 0; }

  .alert-red {
    background: #2d0a0a;
    border-color: #7f1d1d;
    color: #fca5a5;
  }

  /* profile cards */
  .profile-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 14px; margin-bottom: 24px; }
  .profile-card {
    background: var(--surface);
    border: 1px solid #1a3322;
    border-radius: 10px;
    padding: 16px;
  }
  .profile-card-header { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
  .profile-card-emoji { font-size: 1.5rem; }
  .profile-card h3 { font-size: 0.9rem; font-weight: 700; color: var(--accent); }
  .profile-card .behaviors { display: flex; flex-direction: column; gap: 4px; margin-bottom: 12px; }
  .profile-card .behavior { font-size: 0.78rem; color: #86efac; padding-left: 10px; position: relative; }
  .profile-card .behavior::before { content: '·'; position: absolute; left: 0; color: var(--accent); }
  .profile-card .rule { font-size: 0.78rem; background: #000; border-left: 2px solid var(--accent); padding: 7px 10px; border-radius: 0 5px 5px 0; color: #d1fae5; font-style: italic; }

  /* section title */
  .section-title { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); opacity: 0.6; margin: 22px 0 12px; }

  /* home screen */
  .home-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; margin-top: 8px; }
  .home-card {
    background: var(--surface);
    border: 1px solid #1a3322;
    border-radius: 10px;
    padding: 16px;
    cursor: pointer;
    transition: border-color 0.12s, background 0.12s;
  }
  .home-card:hover { border-color: var(--accent); background: #0a1a0f; }
  .home-card .hc-icon { font-size: 1.6rem; margin-bottom: 8px; }
  .home-card .hc-title { font-size: 0.85rem; font-weight: 600; color: #fff; margin-bottom: 4px; }
  .home-card .hc-desc { font-size: 0.72rem; color: #4ade80; opacity: 0.7; line-height: 1.4; }

  /* divider */
  hr { border: none; border-top: 1px solid #1a3322; margin: 22px 0; }

  /* tabs removed */

  /* ── NOTES EDITOR ── */
  .notes-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
  .notes-top h4 { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.09em; color: var(--muted); opacity: 0.65; }
  .btn-add { background: var(--accent); border: none; color: #000; padding: 6px 14px; border-radius: 6px; font-size: 0.75rem; font-weight: 700; font-family: 'Inter', sans-serif; cursor: pointer; transition: opacity 0.1s; }
  .btn-add:hover { opacity: 0.85; }
  .notes-list { display: flex; flex-direction: column; gap: 10px; }
  .note-item { background: #000; border: 1px solid #1a3322; border-radius: 8px; overflow: hidden; transition: border-color 0.12s; }
  .note-item:focus-within { border-color: var(--accent); }
  .note-item-header { display: flex; align-items: center; gap: 8px; padding: 8px 12px; background: #050f08; border-bottom: 1px solid #1a3322; }
  .note-type-select { background: #0a1a0f; border: 1px solid #1a3322; color: #86efac; padding: 3px 8px; border-radius: 4px; font-size: 0.68rem; font-weight: 600; font-family: 'Inter', sans-serif; cursor: pointer; outline: none; }
  .note-type-select option { background: #000; }
  .note-label-input { flex: 1; background: transparent; border: none; color: #86efac; font-size: 0.72rem; font-weight: 600; font-family: 'Inter', sans-serif; outline: none; text-transform: uppercase; letter-spacing: 0.07em; }
  .note-label-input::placeholder { color: #4ade80; opacity: 0.3; }
  .btn-del { background: none; border: none; color: #f87171; cursor: pointer; font-size: 0.75rem; opacity: 0.4; padding: 2px 4px; transition: opacity 0.1s; font-family: 'Inter', sans-serif; }
  .btn-del:hover { opacity: 1; }
  .note-textarea { width: 100%; background: transparent; border: none; color: #d1fae5; font-size: 0.85rem; font-family: 'Inter', sans-serif; line-height: 1.6; padding: 12px 14px; resize: vertical; min-height: 70px; outline: none; font-style: italic; }
  .note-textarea::placeholder { color: #4ade80; opacity: 0.25; font-style: italic; }
  .notes-empty { text-align: center; padding: 36px 20px; color: var(--muted); opacity: 0.3; font-size: 0.83rem; }
  .notes-empty span { display: block; font-size: 1.8rem; margin-bottom: 8px; }

  /* new custom objection form in sidebar */
  .sidebar-add-btn { display: flex; align-items: center; gap: 8px; padding: 8px 20px; cursor: pointer; color: var(--accent); font-size: 0.75rem; font-weight: 600; opacity: 0.6; transition: opacity 0.1s; border: none; background: none; width: 100%; text-align: left; font-family: 'Inter', sans-serif; }
  .sidebar-add-btn:hover { opacity: 1; }
  .custom-obj-item { display: flex; align-items: center; gap: 6px; padding: 8px 20px; cursor: pointer; border-left: 2px solid transparent; transition: background 0.1s; }
  .custom-obj-item:hover { background: #0a1a0f; }
  .custom-obj-item.active { background: #0a1a0f; border-left-color: var(--accent); }
  .custom-obj-item .c-icon { font-size: 0.9rem; flex-shrink: 0; width: 22px; text-align: center; }
  .custom-obj-item .c-label { font-size: 0.78rem; font-weight: 500; color: #d1fae5; flex: 1; }
  .custom-obj-item .del-obj { background: none; border: none; color: #f87171; cursor: pointer; font-size: 0.7rem; opacity: 0; transition: opacity 0.1s; padding: 2px; }
  .custom-obj-item:hover .del-obj { opacity: 0.6; }
  .custom-obj-item .del-obj:hover { opacity: 1 !important; }

  /* ── INLINE EDITING ── */
  [contenteditable="false"] {
    cursor: pointer;
    position: relative;
    transition: outline 0.12s, background 0.12s;
    border-radius: 4px;
    outline: 1px dashed transparent;
  }
  [contenteditable="false"]:hover {
    outline: 1px dashed #22c55e55;
    background: rgba(34,197,94,0.04);
  }
  [contenteditable="false"]:hover::after {
    content: '✏️';
    position: absolute;
    top: -8px;
    right: -4px;
    font-size: 0.7rem;
    opacity: 0.6;
    pointer-events: none;
  }
  [contenteditable="true"].editing {
    outline: 2px solid var(--accent) !important;
    background: rgba(34,197,94,0.06) !important;
    border-radius: 4px;
    cursor: text;
  }
  [contenteditable="true"].editing::after { display: none; }

  /* ── ADD BLOCK BUTTON ── */
  .add-block-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: 1px dashed #1a3322;
    color: var(--accent);
    padding: 9px 18px;
    border-radius: 8px;
    font-size: 0.78rem;
    font-weight: 600;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    transition: all 0.12s;
    margin-top: 4px;
    opacity: 0.65;
    width: 100%;
    justify-content: center;
  }
  .add-block-btn:hover { border-color: var(--accent); opacity: 1; background: #0a1a0f; }

  /* ── CUSTOM BLOCKS ── */
  .custom-blocks { display: flex; flex-direction: column; gap: 10px; margin-top: 10px; }
  .custom-block {
    background: #000;
    border: 1px solid #1a3322;
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.12s;
  }
  .custom-block:focus-within { border-color: var(--accent); }
  .cb-header { display: flex; align-items: center; gap: 8px; padding: 8px 12px; background: #050f08; border-bottom: 1px solid #1a3322; }
  .cb-type-sel { background: #0a1a0f; border: 1px solid #1a3322; color: #86efac; padding: 3px 8px; border-radius: 4px; font-size: 0.68rem; font-weight: 600; font-family: 'Inter', sans-serif; cursor: pointer; outline: none; }
  .cb-type-sel option { background: #000; }
  .cb-label-input { flex: 1; background: transparent; border: none; color: #86efac; font-size: 0.72rem; font-weight: 600; font-family: 'Inter', sans-serif; outline: none; text-transform: uppercase; letter-spacing: 0.07em; }
  .cb-label-input::placeholder { color: #4ade80; opacity: 0.3; }
  .cb-del { background: none; border: none; color: #f87171; cursor: pointer; font-size: 0.75rem; opacity: 0.4; padding: 2px 4px; transition: opacity 0.1s; font-family: 'Inter', sans-serif; }
  .cb-del:hover { opacity: 1; }
  .cb-textarea { width: 100%; background: transparent; border: none; color: #d1fae5; font-size: 0.875rem; font-family: 'Inter', sans-serif; line-height: 1.6; padding: 12px 14px; resize: vertical; min-height: 72px; outline: none; font-style: italic; }
  .cb-textarea::placeholder { color: #4ade80; opacity: 0.25; font-style: italic; }

  /* ── CUSTOM OBJ SIDEBAR ── */
  .custom-obj-item { display: flex; align-items: center; gap: 6px; padding: 8px 20px; cursor: pointer; border-left: 2px solid transparent; transition: background 0.1s; }
  .custom-obj-item:hover { background: #0a1a0f; }
  .custom-obj-item.active { background: #0a1a0f; border-left-color: var(--accent); }
  .custom-obj-item .c-icon { font-size: 0.9rem; flex-shrink: 0; width: 22px; text-align: center; }
  .custom-obj-item .c-label { font-size: 0.78rem; font-weight: 500; color: #d1fae5; flex: 1; }
  .custom-obj-item .del-obj { background: none; border: none; color: #f87171; cursor: pointer; font-size: 0.7rem; opacity: 0; transition: opacity 0.1s; padding: 2px; }
  .custom-obj-item:hover .del-obj { opacity: 0.6; }
  .custom-obj-item .del-obj:hover { opacity: 1 !important; }
  .sidebar-add-btn { display: flex; align-items: center; gap: 8px; padding: 8px 20px; cursor: pointer; color: var(--accent); font-size: 0.75rem; font-weight: 600; opacity: 0.6; transition: opacity 0.1s; border: none; background: none; width: 100%; text-align: left; font-family: 'Inter', sans-serif; }
  .sidebar-add-btn:hover { opacity: 1; }

  /* ── FORM ── */
  .form-inp { flex: 1; min-width: 160px; background: #000; border: 1px solid #1a3322; color: #fff; padding: 8px 12px; border-radius: 6px; font-size: 0.8rem; font-family: 'Inter', sans-serif; outline: none; }
  .form-inp:focus { border-color: var(--accent); }
  .form-inp::placeholder { color: #4ade80; opacity: 0.35; }
  .form-ta { width: 100%; background: #000; border: 1px solid #1a3322; color: #d1fae5; padding: 10px 12px; border-radius: 6px; font-size: 0.82rem; font-family: 'Inter', sans-serif; line-height: 1.6; min-height: 80px; resize: vertical; outline: none; font-style: italic; }
  .form-ta:focus { border-color: var(--accent); }
  .form-ta::placeholder { color: #4ade80; opacity: 0.3; font-style: italic; }
  .btn-save-obj { background: var(--accent); border: none; color: #000; padding: 7px 18px; border-radius: 6px; font-size: 0.78rem; font-weight: 700; font-family: 'Inter', sans-serif; cursor: pointer; }
  .btn-cancel-obj { background: none; border: 1px solid #1a3322; color: #86efac; padding: 7px 14px; border-radius: 6px; font-size: 0.78rem; font-family: 'Inter', sans-serif; cursor: pointer; }

  /* Edit hint in corner */
  .edit-hint {
    font-size: 0.63rem;
    color: var(--muted);
    opacity: 0.4;
    margin-bottom: 10px;
    font-family: 'JetBrains Mono', monospace;
  }

  @media (max-width: 768px) {
    .layout { grid-template-columns: 1fr; }
    .sidebar { position: static; height: auto; border-right: none; border-bottom: 1px solid #1a3322; }
    .variants { grid-template-columns: 1fr; }
    .content { padding: 20px 16px; }
    header { padding: 12px 16px; }
  }
</style>
</head>
<body>

<header>
  <div class="logo">
    <div class="logo-dot"></div>
    <div>
      <h1>Consultor de <span>Retenção</span></h1>
      <p data-key="variant_1" contenteditable="false" onclick="enableEdit(this)">iGreen Energy · Conexão Green</p>
    </div>
  </div>
  <div style="font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:#4ade80;opacity:0.5;">Use enquanto estiver em linha 📞</div>
</header>

<div class="layout">

  <!-- SIDEBAR -->
  <nav class="sidebar">
    <div class="search-wrap">
      <input type="text" id="searchInput" placeholder="🔍  Buscar objeção..." oninput="filterNav(this.value)">
    </div>

    <div class="sidebar-section">
      <div class="sidebar-label">Perfil do Cliente</div>
      <div class="profile-tags">
        <span class="ptag active" onclick="filterProfile('todos', this)">Todos</span>
        <span class="ptag" onclick="filterProfile('idoso', this)">50+ / Idoso</span>
        <span class="ptag" onclick="filterProfile('conta-unica', this)">Conta Única</span>
        <span class="ptag" onclick="filterProfile('duas-contas', this)">Duas Contas</span>
        <span class="ptag" onclick="filterProfile('troca-tit', this)">C/ Troca Tit.</span>
        <span class="ptag" onclick="filterProfile('sem-troca', this)">Sem Troca Tit.</span>
      </div>
    </div>

    <div class="sidebar-section">
      <div class="sidebar-label">Objeções</div>
      <div id="navList">
        <div class="nav-item" onclick="showCard('home')"><span class="icon">🏠</span><span class="label">Início</span></div>
        <div class="nav-item" data-tags="desconto economia baixo" onclick="showCard('obj1')"><span class="icon">💸</span><span class="label">Não vejo economia / desconto baixo</span></div>
